import pandas as pd
import math
from collections import Counter
from itertools import product

# === Load Dataset ===
print("Loading dataset...")
df = pd.read_excel("demo.xlsx")

# Column names in your file
mirna_col = "miRNA_NAME"
seq_col = "Sequences"

# === Helper functions ===
def nucleotide_composition(seq):
    counts = Counter(seq)
    total = len(seq)
    return {nt: counts.get(nt, 0)/total for nt in "AUGC"}

def dinucleotide_freq(seq):
    pairs = [seq[i:i+2] for i in range(len(seq)-1)]
    counts = Counter(pairs)
    total = len(pairs) if pairs else 1
    return {"di_"+p: counts.get(p, 0)/total for p in ["".join(x) for x in product("AUGC", repeat=2)]}

def trinucleotide_freq(seq):
    triplets = [seq[i:i+3] for i in range(len(seq)-2)]
    counts = Counter(triplets)
    total = len(triplets) if triplets else 1
    return {"tri_"+t: counts.get(t, 0)/total for t in ["".join(x) for x in product("AUGC", repeat=3)]}

def tetranucleotide_freq(seq):
    quads = [seq[i:i+4] for i in range(len(seq)-3)]
    counts = Counter(quads)
    total = len(quads) if quads else 1
    return {q: counts.get(q, 0)/total for q in ["".join(x) for x in product("AUGC", repeat=4)]}

def gc_content(seq):
    return (seq.count("G") + seq.count("C")) / len(seq) if seq else 0
def au(seq):
    return (seq.count("A") + seq.count("U")) / len(seq) if seq else 0

def shannon_entropy(seq):
    counts = Counter(seq)
    total = len(seq)
    entropy = 0
    for base in counts:
        p = counts[base]/total
        entropy -= p * math.log2(p)
    return entropy

def extract_seed_features(seq):
    seed = seq[1:7] if len(seq) >= 7 else seq
    return {
        "Seed_seq": seed,
        "Seed_GC": gc_content(seed),
         "Seed_AU": au(seed),
        "Seed_entropy": shannon_entropy(seed)
    }

# === Feature Extraction ===
features = []
for _, row in df.iterrows():
    seq = str(row[seq_col]).upper().replace("T","U")  # normalize to RNA alphabet
    feats = {
        "miRNA_NAME": row[mirna_col],
        "Sequence": seq,
        "Length": len(seq),
        "GC_Content": gc_content(seq),
        "Entropy": shannon_entropy(seq)
    }
    feats.update(nucleotide_composition(seq))
    feats.update(dinucleotide_freq(seq))
    feats.update(trinucleotide_freq(seq))
    feats.update(tetranucleotide_freq(seq))
    feats.update(extract_seed_features(seq))
    features.append(feats)

features_df = pd.DataFrame(features)

# === Save Outputs====
features_df.to_excel("sequence_features.xlsx", index=False)


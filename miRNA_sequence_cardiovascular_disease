import pandas as pd
import RNA  # from ViennaRNA

# Load dataset
file_path = "sequence_features.xlsx"
df = pd.read_excel(file_path)

sequence_column = "Sequence"  # your dataset's sequence column

def analyze_structure(structure):
    # Count base pairs
    base_pairs = structure.count('(')
    length = len(structure)
    # Calculate base-pair ratio
    base_pair_ratio = base_pairs / length

    # Calculate stem length (longest continuous run of paired bases)
    max_stem = max((len(x) for x in ''.join('1' if c in '()' else '0' for c in structure).split('0')), default=0)

    # Count loops: number of unpaired regions ('.')
    loop_count = structure.count('.')

    return base_pairs, base_pair_ratio, max_stem, loop_count

# Function to get structure & MFE and extra features
def get_rnafold_features(seq):
    seq = seq.replace("T", "U")  # RNA uses U instead of T
    (structure, mfe) = RNA.fold(seq)  # ViennaRNA API

    base_pairs, base_pair_ratio, stem_length, loop_count = analyze_structure(structure)

    return structure, mfe, base_pairs, base_pair_ratio, stem_length, loop_count

# Apply to all sequences
results = df[sequence_column].apply(get_rnafold_features)

# Unpack results into separate columns
df["Structure"], df["MFE"], df["Base_Pairs"], df["Base_Pair_Ratio"], df["Max_Stem_Length"], df["Loop_Count"] = zip(*results)

# Save results
df.to_excel("dataset_with_secondary_features.xlsx", index=False)

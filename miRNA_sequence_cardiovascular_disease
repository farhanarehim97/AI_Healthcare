# ---------------------------
import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split
from xgboost import XGBClassifier
from sklearn.ensemble import VotingClassifier, RandomForestClassifier
from sklearn.linear_model import LogisticRegression
from sklearn.svm import SVC
from sklearn.metrics import accuracy_score, classification_report, roc_auc_score, confusion_matrix
from sklearn.metrics import roc_curve
import joblib

# ---------------------------
# 2️⃣ Load dataset
# ---------------------------
df = pd.read_excel("dataset_enhanced_features.xlsx")
# ---------------------------
# 3️⃣ Create derived features
# ---------------------------
df['MFE_norm'] = df['MFE'] / df['Length']
df['Stem_Loop_Ratio'] = df['Max_Stem_Length'] / (df['Loop_Count'] + 1)
df['BasePair_Density'] = df['Base_Pair_Ratio'] * df['Length']
df['Seed_entropy_norm'] = df['Seed_entropy'] / 3.0
df['GC_kmer_ratio'] = df['GC_Content'] / (df['G'] + df['C'] + 1e-6)

# Feature interactions
df['GC_Stem'] = df['GC_Content'] * df['Max_Stem_Length']
df['U_Loop'] = df['U'] * df['Loop_Count']
df['BP_MFE'] = df['Base_Pair_Ratio'] * df['MFE_norm']

# ---------------------------
# 4️⃣ Select features & label
# ---------------------------
top_features = [
    'tri_GAG','di_AA','di_UA','GC_Content','GGGA','GGAC','di_GG','tri_GGA',
    'tri_CUA','G','tri_UAA','tri_GAC','UACA','tri_AGG','GGAG','tri_AGU','CAGU','Seed_AU'
]
derived_features = ['MFE_norm','Stem_Loop_Ratio','BasePair_Density','Seed_entropy_norm','GC_kmer_ratio']
interaction_features = ['GC_Stem','U_Loop','BP_MFE']


# Combine all features
X = df[top_features + derived_features + interaction_features]
y = df['Label']

# ---------------------------
# 5️⃣ Scale features
# ---------------------------
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)
joblib.dump(scaler, "scaler.pkl")
print("✅ Scaler saved as 'scaler.pkl'")

# ---------------------------
# 6️⃣ Train-test split
# ---------------------------
X_train, X_test, y_train, y_test = train_test_split(
    X_scaled, y, test_size=0.2, random_state=42, stratify=y
)

# ---------------------------
# 7️⃣ Define individual models
# ---------------------------
svm_model = SVC(C=50, gamma=0.01, kernel='sigmoid', probability=True, class_weight='balanced')
xgb_model = XGBClassifier(eval_metric='logloss', n_estimators=200, max_depth=3)
rf_model = RandomForestClassifier(n_estimators=300, max_depth=10, max_features='sqrt', min_samples_split=10, random_state=42)
lr_model = LogisticRegression(max_iter=1000, class_weight='balanced', random_state=42)
# ---------------------------
# 📊 Evaluate Individual Models
# ---------------------------

models = {
    "SVM": svm_model,
    "XGBoost": xgb_model,
    "Random Forest": rf_model,
    "Logistic Regression": lr_model
}

for name, model in models.items():
    print(f"\n🔹 Model: {name}")

    # Train
    model.fit(X_train, y_train)

    # Predict
    y_pred_ind = model.predict(X_test)

    # Probabilities (for ROC-AUC)
    if hasattr(model, "predict_proba"):
        y_prob_ind = model.predict_proba(X_test)[:,1]
    else:
        y_prob_ind = model.decision_function(X_test)

    # Metrics
    print("Accuracy:", accuracy_score(y_test, y_pred_ind))
    print("ROC-AUC:", roc_auc_score(y_test, y_prob_ind))
    print("Confusion Matrix:\n", confusion_matrix(y_test, y_pred_ind))

# ---------------------------
# 8️⃣ Final Ensemble: Soft Voting
# ---------------------------
ensemble = VotingClassifier(
    estimators=[
        ('svm', svm_model),
        ('xgb', xgb_model),
        ('rf', rf_model),
        ('lr', lr_model)
    ],
    voting='soft',
    weights=[3,3,2,1]  # SVM and XGBoost have higher weight
)

# ---------------------------
# 9️⃣ Train ensemble
# ---------------------------
ensemble.fit(X_train, y_train)

# ---------------------------
# 🔟 Evaluate
# ---------------------------
y_pred = ensemble.predict(X_test)
y_prob = ensemble.predict_proba(X_test)[:,1]

print("Accuracy:", accuracy_score(y_test, y_pred))
print("\nClassification Report:\n", classification_report(y_test, y_pred))
print("ROC-AUC:", roc_auc_score(y_test, y_prob))
print("Confusion Matrix:\n", confusion_matrix(y_test, y_pred))

